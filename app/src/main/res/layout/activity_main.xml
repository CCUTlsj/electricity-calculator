<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F5F5F5">

    <!-- 标题 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="电费计算器"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#1976D2"
        android:gravity="center"
        android:paddingBottom="20dp" />

    <!-- 省份选择 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="选择省份"
        android:textSize="16sp"
        android:textColor="#333333"
        android:paddingTop="8dp"
        android:paddingBottom="4dp" />

    <Spinner
        android:id="@+id/spinnerProvince"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@android:drawable/btn_dropdown"
        android:padding="4dp" />

    <!-- 城市选择 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="选择城市"
        android:textSize="16sp"
        android:textColor="#333333"
        android:paddingTop="12dp"
        android:paddingBottom="4dp" />

    <Spinner
        android:id="@+id/spinnerCity"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@android:drawable/btn_dropdown"
        android:padding="4dp" />

    <!-- 档位显示 -->
    <TextView
        android:id="@+id/tvTierInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="当前城市阶梯电价"
        android:textSize="14sp"
        android:textColor="#666666"
        android:paddingTop="16dp"
        android:paddingBottom="4dp" />

    <TableLayout
        android:id="@+id/tableTiers"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:stretchColumns="1"
        android:background="#FFFFFF"
        android:padding="8dp">

        <TableRow>
            <TextView android:text="档位" android:padding="8dp" android:textStyle="bold" />
            <TextView android:text="单价(元/度)" android:padding="8dp" android:textStyle="bold" />
        </TableRow>
        <TableRow android:id="@+id/rowTier1">
            <TextView android:text="第一档" android:padding="8dp" />
            <TextView android:id="@+id/tvPrice1" android:text="-" android:padding="8dp" />
        </TableRow>
        <TableRow android:id="@+id/rowTier2">
            <TextView android:text="第二档" android:padding="8dp" />
            <TextView android:id="@+id/tvPrice2" android:text="-" android:padding="8dp" />
        </TableRow>
        <TableRow android:id="@+id/rowTier3">
            <TextView android:text="第三档" android:padding="8dp" />
            <TextView android:id="@+id/tvPrice3" android:text="-" android:padding="8dp" />
        </TableRow>
    </TableLayout>

    <!-- 用电量输入 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="输入用电量（度）"
        android:textSize="16sp"
        android:textColor="#333333"
        android:paddingTop="16dp"
        android:paddingBottom="4dp" />

    <EditText
        android:id="@+id/editUsage"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="请输入用电量"
        android:inputType="numberDecimal"
        android:background="@android:drawable/edit_text"
        android:padding="8dp" />

    <!-- 计算按钮 -->
    <Button
        android:id="@+id/btnCalculate"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="计算电费"
        android:textSize="18sp"
        android:layout_marginTop="16dp"
        android:backgroundTint="#1976D2" />

    <!-- 计算结果 -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:contentPadding="16dp"
        app:cardBackgroundColor="#E3F2FD">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="计算结果"
                android:textSize="14sp"
                android:textColor="#666666" />

            <TextView
                android:id="@+id/tvResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="等待输入..."
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#1565C0"
                android:paddingTop="8dp" />

            <TextView
                android:id="@+id/tvDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="13sp"
                android:textColor="#555555"
                android:paddingTop="4dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
